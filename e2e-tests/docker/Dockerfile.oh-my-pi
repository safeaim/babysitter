FROM node:20-bookworm

RUN apt-get update && apt-get install -y \
    bash \
    git \
    jq \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r omp && useradd -r -g omp -m -d /home/omp omp

ENV HOME=/home/omp
ENV PATH=/home/omp/.local/bin:${PATH}

RUN mkdir -p /home/omp/.local && \
    echo "prefix=/home/omp/.local" > /home/omp/.npmrc

WORKDIR /app

COPY package.json package-lock.json* ./
COPY packages/sdk/package.json ./packages/sdk/
COPY plugins/babysitter-omp/package.json ./plugins/babysitter-omp/
COPY third_party/webpackbar ./third_party/webpackbar

RUN npm install --include=dev

COPY . .

RUN npm run build:sdk && chown -R omp:omp /app /home/omp

USER omp

RUN npm install -g bun
RUN npm install -g @oh-my-pi/pi-coding-agent @a5c-ai/babysitter-sdk /app/plugins/babysitter-omp

WORKDIR /workspace

ENV A5C_PROVIDER_NAME=""
ENV A5C_SELECTED_CLI_COMMAND=""
ENV A5C_CLI_TOOL=""
ENV A5C_SELECTED_MODEL=""

CMD ["bash"]
