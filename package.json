{
  "name": "babysitter",
  "version": "5.0.0",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/agent-mux/*",
    "packages/atlas/*",
    "packages/hooks-mux/core",
    "packages/hooks-mux/cli",
    "packages/hooks-mux/adapter-claude",
    "packages/hooks-mux/adapter-codex",
    "packages/hooks-mux/adapter-gemini",
    "packages/hooks-mux/adapter-copilot",
    "packages/hooks-mux/adapter-cursor",
    "packages/hooks-mux/adapter-pi",
    "packages/hooks-mux/adapter-oh-my-pi",
    "packages/hooks-mux/adapter-opencode",
    "packages/hooks-mux/adapter-openclaw"
  ],
  "scripts": {
    "check:library-syntax": "node ./scripts/validate-library-js-syntax.cjs",
    "verify:metadata": "node ./scripts/check-package-metadata.cjs",
    "verify:library-metadata": "node packages/atlas/scripts/verify-library-metadata.mjs",
    "test:agent-catalog-contracts": "npm exec --yes --package=vitest -- vitest run --config vitest.config.ts \"packages/agent-catalog/src/catalog.test.ts\" \"packages/agent-catalog/src/discovery.contract.test.ts\" \"packages/agent-catalog/src/sdk.contract.test.ts\" \"packages/agent-catalog/src/discovery.packaged.test.ts\" \"packages/sdk/src/harness/amuxFallbackMetadata.contract.test.ts\" \"packages/hooks-mux/core/src/discovery/__tests__/detector.contract.test.ts\" \"packages/agent-mux/core/tests/host-detection.contract.test.ts\" \"packages/agent-mux/core/tests/invocation.contract.test.ts\" \"packages/agent-plugins-mux/src/__tests__/targets.contract.test.ts\"",
    "verify:v6:seams": "npm run test:seams --workspace=@a5c-ai/babysitter-agent",
    "test:architecture": "npm run verify:v6:seams && node ./scripts/check-architecture-boundaries.cjs",
    "sync:sdk-command-templates": "node ./scripts/sync-sdk-command-templates.cjs",
    "check:sdk-command-templates": "node ./scripts/sync-sdk-command-templates.cjs --check",
    "sync:plugin-commands": "node ./scripts/sync-plugin-commands.cjs",
    "check:plugin-commands": "node ./scripts/sync-plugin-commands.cjs --check",
    "test:sdk": "npm run test --workspace=@a5c-ai/babysitter-sdk",
    "test:library": "vitest run --config library/vitest.config.mjs",
    "build:sdk": "npm run build --workspace=@a5c-ai/atlas && npm run build --workspace=@a5c-ai/agent-catalog && npm run build --workspace=@a5c-ai/babysitter-sdk",
    "build:agent-mux:non-realtime": "npm run build --workspace=@a5c-ai/agent-mux-observability && npm run build --workspace=@a5c-ai/agent-mux-core && npm run build --workspace=@a5c-ai/agent-mux-adapters && npm run build --workspace=@a5c-ai/agent-mux-gateway && npm run build --workspace=@a5c-ai/transport-mux && npm run build --workspace=@a5c-ai/agent-mux-cli && npm run build --workspace=@a5c-ai/agent-mux",
    "build:runtime:agent-core-deps": "npm run build:sdk && npm run build:agent-mux:non-realtime",
    "build:runtime:babysitter-agent-deps": "npm run build:runtime:agent-core-deps && npm run build --workspace=@a5c-ai/agent-core",
    "build:runtime": "npm run build:runtime:babysitter-agent-deps && npm run build --workspace=@a5c-ai/babysitter-agent",
    "token:eval": "bash scripts/eval-compression.sh",
    "build:observer": "npm run build --workspace=@a5c-ai/babysitter-observer-dashboard",
    "test:observer": "npm run test --workspace=@a5c-ai/babysitter-observer-dashboard",
    "build:cloud": "npm run build --workspace=@a5c-ai/cloud",
    "test:cloud": "npm run test --workspace=@a5c-ai/cloud",
    "coverage:cloud": "npm run test:coverage --workspace=@a5c-ai/cloud",
    "verify:cloud-release": "npm run verify:release --workspace=@a5c-ai/cloud",
    "deploy:cloud:staging": "npm run build:cloud && node ./packages/cloud/dist/cli.js install --env staging",
    "deploy:cloud:prod": "npm run build:cloud && node ./packages/cloud/dist/cli.js install --env prod",
    "build:realtime-flow": "npm run build:realtime --workspace=@a5c-ai/agent-mux-ui && npm run build:realtime --workspace=@a5c-ai/agent-mux-webui",
    "test:realtime-flow": "npm run test:realtime --workspace=@a5c-ai/agent-mux-ui && npm run test:realtime --workspace=@a5c-ai/agent-mux-webui",
    "verify:realtime-flow-release": "npm run verify:release --workspace=@a5c-ai/agent-mux-ui && npm run verify:release --workspace=@a5c-ai/agent-mux-webui",
    "build:atlas": "npm run build --workspace=@a5c-ai/atlas",
    "build:agent-mux": "node scripts/agent-mux-build.cjs build",
    "test:agent-mux": "node scripts/agent-mux-build.cjs build && node scripts/agent-mux-build.cjs test",
    "build:hooks-mux": "node scripts/hooks-mux-build.cjs build",
    "test:hooks-mux": "node scripts/hooks-mux-build.cjs test",
    "lint:hooks-mux": "node scripts/hooks-mux-build.cjs lint",
    "generate:plugins": "node scripts/generate-plugins.mjs --output artifacts/generated-plugins",
    "compare:plugins": "npm run generate:plugins",
    "generate:process-library-docs": "node ./scripts/generate-process-library-doc-artifacts.cjs",
    "build:agent-plugins-mux": "npm run build --workspace=@a5c-ai/agent-plugins-mux",
    "test:agent-plugins-mux": "npm run test --workspace=@a5c-ai/agent-plugins-mux",
    "docs:prepare": "node ./scripts/generate-process-library-doc-artifacts.cjs && node ./scripts/generate-cli-examples-artifacts.cjs && node ./scripts/ensure-webpackbar-patch.cjs",
    "docs:examples:generate": "node ./scripts/generate-cli-examples-artifacts.cjs",
    "docs:examples:smoke": "npm run smoke:cli --workspace=@a5c-ai/babysitter-sdk",
    "docs:examples:verify": "npm run build --workspace=@a5c-ai/babysitter-sdk && npm run docs:prepare && npm run docs:examples:smoke && npm run docs:qa",
    "docs:lint:markdown": "markdownlint-cli2",
    "docs:lint:style": "node ./scripts/docs-style-check.cjs",
    "docs:lint": "npm run docs:lint:markdown && npm run docs:lint:style",
    "docs:snippets": "node ./scripts/docs-code-samples-check.cjs",
    "docs:links": "node ./scripts/docs-link-check.cjs && node ./scripts/docs-strict-build.cjs",
    "docs:freshness": "node ./scripts/docs-freshness-report.cjs",
    "docs:qa": "npm run docs:lint && npm run docs:snippets && npm run docs:links && npm run docs:freshness",
    "docs:ci": "npm run docs:qa",
    "docs:dev": "npm run docs:prepare && docusaurus start docs-site --host 0.0.0.0",
    "docs:build": "npm run docs:prepare && docusaurus build docs-site",
    "docs:serve": "docusaurus serve docs-site/build",
    "docs:clear": "docusaurus clear docs-site",
    "sync:external-plugins": "node scripts/sync-external-plugin-repos.mjs",
    "validate:edges": "node packages/atlas/scripts/validate-edges.mjs",
    "test:e2e:live-stack:primary": "vitest run --config vitest.config.ts packages/agent-mux/cli/tests/live-stack/primary-live-runner.test.ts",
    "test:e2e:live-stack:framework": "vitest run --config vitest.config.ts packages/agent-mux/cli/tests/live-stack/scenario-contract.test.ts",
    "test:e2e:live-stack": "npm run test:e2e:live-stack:framework && npm run test:e2e:live-stack:primary",
    "coverage:e2e:live-stack": "node scripts/live-stack-coverage-report.cjs",
    "test:e2e:live-stack:pipeline": "vitest run --config vitest.config.ts packages/agent-mux/cli/tests/live-stack/pipeline-scenario.test.ts",
    "test:e2e:agent-mux-hooks-mux": "vitest run --config vitest.config.ts packages/agent-mux/cli/tests/e2e/agent-mux-hooks-mux.pipeline.test.ts"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.113",
    "@docusaurus/core": "^3.0.0",
    "@docusaurus/preset-classic": "^3.0.0",
    "@mdx-js/react": "^3.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "markdownlint-cli2": "^0.18.1",
    "prism-react-renderer": "^2.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom-v6": "npm:react-router-dom@^6.30.2",
    "webpackbar": "file:third_party/webpackbar"
  },
  "overrides": {
    "webpackbar": "file:third_party/webpackbar",
    "@radix-ui/react-dialog": {
      "@types/react": "18.2.79"
    },
    "@radix-ui/react-accordion": {
      "@types/react": "18.2.79"
    },
    "@radix-ui/react-scroll-area": {
      "@types/react": "18.2.79"
    },
    "@radix-ui/react-separator": {
      "@types/react": "18.2.79"
    },
    "@radix-ui/react-slot": {
      "@types/react": "18.2.79"
    },
    "@radix-ui/react-tabs": {
      "@types/react": "18.2.79"
    },
    "@radix-ui/react-tooltip": {
      "@types/react": "18.2.79"
    }
  },
  "dependencies": {
    "@a5c-ai/agent-mux": "^5.0.0",
    "@a5c-ai/compendium": "^0.1.0"
  }
}
