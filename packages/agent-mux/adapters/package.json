{
  "name": "@a5c-ai/agent-mux-adapters",
  "version": "5.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Built-in agent adapters for agent-mux",
  "author": "a5c-ai",
  "homepage": "https://github.com/a5c-ai/babysitter/tree/main/packages/agent-mux/adapters#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/babysitter.git",
    "directory": "packages/agent-mux/adapters"
  },
  "bugs": {
    "url": "https://github.com/a5c-ai/babysitter/issues"
  },
  "keywords": [
    "agent-mux",
    "adapters",
    "claude-code",
    "codex",
    "gemini",
    "copilot",
    "cursor",
    "ai"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build && tsc --emitDeclarationOnly --declarationMap false -p tsconfig.json",
    "test": "vitest run --config ../../../vitest.config.ts \"tests/**/*.test.ts\" \"tests/**/*.test.tsx\" \"src/**/*.test.ts\" \"src/**/*.test.tsx\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@a5c-ai/agent-catalog": "5.0.0",
    "@a5c-ai/agent-comm-mux": "5.0.0",
    "@anthropic-ai/claude-agent-sdk": "0.3.150",
    "ws": "^8.20.0"
  },
  "atlas": {
    "layers": [
      "L5"
    ],
    "muxes": [
      "agent-mux"
    ]
  }
}
