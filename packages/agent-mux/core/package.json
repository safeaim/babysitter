{
  "name": "@a5c-ai/agent-mux-core",
  "version": "0.4.9",
  "type": "module",
  "license": "MIT",
  "description": "Core types, client, and stream engine for agent-mux",
  "author": "a5c-ai",
  "homepage": "https://github.com/a5c-ai/babysitter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/babysitter.git",
    "directory": "packages/agent-mux/core"
  },
  "bugs": {
    "url": "https://github.com/a5c-ai/babysitter/issues"
  },
  "keywords": [
    "agent-mux",
    "claude",
    "codex",
    "coding-agent",
    "llm",
    "cli",
    "harness",
    "ai"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build && tsc --emitDeclarationOnly --declarationMap false -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run --config ../../../vitest.config.ts \"tests/**/*.test.ts\" \"tests/**/*.test.tsx\" \"src/**/*.test.ts\" \"src/**/*.test.tsx\""
  },
  "dependencies": {
    "@a5c-ai/agent-mux-observability": "*"
  }
}
