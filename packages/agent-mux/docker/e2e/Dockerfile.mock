# E2E image: runs the full agent-mux CLI against harness-mock only.
# No real agent CLIs, no credentials. Reproducible in CI and locally.

FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
COPY tsconfig*.json ./
COPY packages ./packages
RUN npm ci && npm run build

FROM node:22-alpine
WORKDIR /app
COPY --from=build /app /app
ENV USE_MOCK_HARNESS=true
ENV AMUX_MOCK_HARNESS_BIN=/app/packages/harness-mock/dist/bin/mock-harness.js
ENTRYPOINT ["node", "/app/packages/cli/dist/index.js"]
