# E2E image: runs the full agent-mux CLI against real agent CLIs.
# Requires credentials injected via environment at runtime.
#
# Installed CLIs: claude-code, codex. Extend as needed.

FROM node:22-slim AS build
WORKDIR /app
COPY package*.json ./
COPY tsconfig*.json ./
COPY packages ./packages
RUN npm ci && npm run build

FROM node:22-slim
RUN apt-get update && apt-get install -y --no-install-recommends curl git ca-certificates \
    && rm -rf /var/lib/apt/lists/*
RUN npm install -g @anthropic-ai/claude-code @openai/codex
WORKDIR /app
COPY --from=build /app /app
ENTRYPOINT ["node", "/app/packages/cli/dist/index.js"]
