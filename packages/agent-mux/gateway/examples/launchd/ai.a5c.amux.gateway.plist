<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>ai.a5c.amux.gateway</string>
    <key>ProgramArguments</key>
    <array>
      <string>/usr/bin/env</string>
      <string>amux</string>
      <string>gateway</string>
      <string>serve</string>
      <string>--config</string>
      <string>/Users/you/.amux/gateway/config.yml</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
  </dict>
</plist>
