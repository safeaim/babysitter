{
  "name": "@a5c-ai/agent-mux-gateway",
  "version": "5.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Gateway package for remote and browser-facing agent-mux surfaces",
  "author": "a5c-ai",
  "homepage": "https://github.com/a5c-ai/babysitter/tree/main/packages/agent-mux/gateway#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/babysitter.git",
    "directory": "packages/agent-mux/gateway"
  },
  "bugs": {
    "url": "https://github.com/a5c-ai/babysitter/issues"
  },
  "keywords": [
    "agent-mux",
    "gateway",
    "websocket",
    "remote",
    "sdk"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build && tsc --emitDeclarationOnly --declarationMap false -p tsconfig.json",
    "test": "vitest run --root ../../.. --config vitest.config.ts packages/agent-mux/gateway/tests/builtin-adapters.test.ts packages/agent-mux/gateway/tests/e2e.test.ts packages/agent-mux/gateway/tests/event-log.test.ts packages/agent-mux/gateway/tests/manager.test.ts packages/agent-mux/gateway/tests/protocol.test.ts packages/agent-mux/gateway/tests/server.test.ts packages/agent-mux/gateway/tests/session-runtime.test.ts packages/agent-mux/gateway/tests/tokens.test.ts packages/agent-mux/gateway/tests/webhook-out.test.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@a5c-ai/agent-mux-adapters": "5.0.0",
    "@a5c-ai/agent-comm-mux": "5.0.0",
    "@hono/node-server": "^1.19.14",
    "argon2": "^0.44.0",
    "hono": "^4.12.14",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "atlas": {
    "layers": [
      "L6"
    ],
    "muxes": [
      "agent-mux"
    ]
  }
}
