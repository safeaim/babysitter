{
  "name": "@a5c-ai/agent-mux-observability",
  "version": "5.0.0",
  "description": "Logging and telemetry infrastructure for agent-mux",
  "keywords": [
    "logging",
    "telemetry",
    "observability",
    "opentelemetry",
    "pino"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/babysitter.git",
    "directory": "packages/agent-mux/observability"
  },
  "homepage": "https://github.com/a5c-ai/babysitter/tree/main/packages/agent-mux/observability#readme",
  "bugs": {
    "url": "https://github.com/a5c-ai/babysitter/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && tsc --emitDeclarationOnly --declarationMap false -p tsconfig.json",
    "clean": "rm -rf dist/",
    "test": "vitest run --config ../../../vitest.config.ts \"tests/**/*.test.ts\" \"tests/**/*.test.tsx\" \"src/**/*.test.ts\" \"src/**/*.test.tsx\""
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.29.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^4.1.4"
  },
  "atlas": {
    "layers": [
      "cross-cutting"
    ],
    "muxes": [
      "agent-mux"
    ]
  }
}
