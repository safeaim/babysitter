{
  "name": "@a5c-ai/agent-mux-ui",
  "version": "0.4.9",
  "type": "module",
  "license": "MIT",
  "description": "Shared UI foundation and session-flow projection surface for browser and React Native agent-mux apps",
  "author": "a5c-ai",
  "homepage": "https://github.com/a5c-ai/babysitter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/babysitter.git",
    "directory": "packages/agent-mux/ui"
  },
  "bugs": {
    "url": "https://github.com/a5c-ai/babysitter/issues"
  },
  "keywords": [
    "agent-mux",
    "ui",
    "session-flow",
    "timeline",
    "realtime",
    "react-native-web",
    "react-native",
    "gateway"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./gateway": {
      "import": {
        "types": "./dist/gateway.d.ts",
        "default": "./dist/gateway.js"
      }
    },
    "./protocol": {
      "import": {
        "types": "./dist/protocol/v1.d.ts",
        "default": "./dist/protocol/v1.js"
      }
    },
    "./session-flow": {
      "import": {
        "types": "./dist/session-flow.d.ts",
        "default": "./dist/session-flow.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run codegen && tsc --build && tsc --emitDeclarationOnly --declarationMap false -p tsconfig.json",
    "codegen": "tsx src/codegen/swift-types.ts && tsx src/codegen/kotlin-types.ts",
    "test": "vitest run --config ../../../vitest.config.ts \"tests/**/*.test.ts\" \"tests/**/*.test.tsx\" \"src/**/*.test.ts\" \"src/**/*.test.tsx\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@a5c-ai/agent-mux-core": "0.4.9",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "^0.74.5",
    "react-native-web": "^0.21.2",
    "ts-morph": "^25.0.1",
    "ws": "^8.18.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/react": "^18.2.79"
  }
}
