  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/babysitter.git",
    "directory": "packages/agent-plugins-mux"
  },
  "homepage": "https://github.com/a5c-ai/babysitter/tree/main/packages/agent-plugins-mux#readme",
  "bugs": {
