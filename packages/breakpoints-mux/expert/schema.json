{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anthropic.com/bpx/expert-profile.schema.json",
  "title": "ExpertProfile",
  "description": "Schema for an expert profile used by the Breakpoints Pro system.",
  "type": "object",
  "required": ["id", "name", "title", "expertiseAreas", "availability", "responseTimeSla"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for the expert."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Display name of the expert."
    },
    "title": {
      "type": "string",
      "description": "Professional title or role."
    },
    "expertiseAreas": {
      "type": "array",
      "description": "Array of expertise domains the expert covers.",
      "items": {
        "$ref": "#/$defs/ExpertiseArea"
      }
    },
    "availability": {
      "type": "boolean",
      "description": "Whether the expert is currently available for questions."
    },
    "sessionConfig": {
      "type": "object",
      "description": "Optional arbitrary configuration for expert sessions.",
      "additionalProperties": true
    },
    "responseTimeSla": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Maximum expected response time in milliseconds."
    }
  },
  "$defs": {
    "ExpertiseArea": {
      "type": "object",
      "required": ["domain", "topics", "keywords", "proficiency"],
      "additionalProperties": false,
      "properties": {
        "domain": {
          "type": "string",
          "minLength": 1,
          "description": "High-level domain name (e.g., 'frontend', 'backend', 'devops')."
        },
        "topics": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Specific technologies or subjects within the domain."
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Search keywords used for matching questions to this expertise."
        },
        "proficiency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "Self-assessed proficiency level (1 = beginner, 5 = expert)."
        }
      }
    }
  }
}
