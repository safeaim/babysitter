{
  "name": "@a5c-ai/kanban",
  "version": "1.0.0",
  "description": "Board-, issue-, and workspace-first kanban surface for Babysitter orchestration",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "bin": {
    "kanban": "./dist/cli.js",
    "kanban-mcp-server": "./dist/mcp-server.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/a5c-ai/babysitter.git"
  },
  "homepage": "https://github.com/a5c-ai/babysitter/tree/main/packages/kanban#readme",
  "bugs": {
    "url": "https://github.com/a5c-ai/babysitter/issues"
  },
  "keywords": [
    "kanban",
    "board",
    "issue",
    "babysitter",
    "agent-mux",
    "workspace",
    "observability",
    "review",
    "nextjs",
    "sse",
    "real-time"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "src",
    ".next/server",
    ".next/static",
    ".next/BUILD_ID",
    ".next/*.json",
    ".next/package.json",
    "public",
    "specs",
    "next.config.mjs",
    "postcss.config.mjs",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "next dev --port 4800",
    "dev:cli": "npx ts-node --skip-project src/cli.ts",
    "build": "npm run build --workspace=@a5c-ai/agent-mux-observability && npm run build --workspace=@a5c-ai/agent-mux-core && npm run build --workspace=@a5c-ai/agent-mux-ui && next build",
    "build:cli": "node -e \"const v=require('./package.json').version;require('esbuild').buildSync({entryPoints:['src/cli.ts'],bundle:true,platform:'node',target:'node18',outfile:'dist/cli.js',external:['next'],define:{'__CLI_VERSION__':JSON.stringify(v)}})\"",
    "build:mcp-server": "node -e \"const v=require('./package.json').version;require('esbuild').buildSync({entryPoints:['src/mcp/cli.ts'],bundle:true,platform:'node',target:'node18',outfile:'dist/mcp-server.js',banner:{js:'#!/usr/bin/env node'},external:['@a5c-ai/agent-mux-core','@a5c-ai/agent-mux-core/kanban'],define:{'__KANBAN_MCP_VERSION__':JSON.stringify(v)}})\"",
    "start": "next start --port 4800",
    "lint": "next lint",
    "verify:release": "node ./scripts/verify-release.mjs",
    "prepublishOnly": "npm run build && npm run build:cli && npm run build:mcp-server && npm run verify:release",
    "pretest": "node scripts/ensure-local-deps.mjs",
    "test": "vitest run",
    "test:dispatch-context-labels": "npm run build --workspace=@a5c-ai/agent-catalog && npm run build --workspace=@a5c-ai/agent-mux-observability && npm run build --workspace=@a5c-ai/agent-mux-core && vitest run src/lib/services/__tests__/dispatch-context-label-service.test.ts src/lib/services/__tests__/backlog-query-service.test.ts src/hooks/__tests__/use-backlog.test.ts src/app/settings/__tests__/page.test.tsx src/lib/__tests__/release-verification.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:perf": "npx playwright test e2e/tests/performance.spec.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@a5c-ai/agent-mux-core": "0.4.9",
    "@a5c-ai/agent-mux-ui": "0.4.9",
    "@a5c-ai/compendium": "^0.1.0",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.19",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.469.0",
    "next": "16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^2.2.0",
    "ulid": "^3.0.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@adobe/css-tools": "^4.4.4",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "16.2.3",
    "jsdom": "^24.1.3",
    "msw": "^2.12.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
