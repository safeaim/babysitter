{
  "name": "@a5c-ai/omni",
  "version": "5.0.0",
  "description": "Omni — unified agent product integrating core, runtime, platform, and TUI",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/main.d.ts",
      "require": "./dist/cli/main.js",
      "default": "./dist/cli/main.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "omni": "./dist/cli/main.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build:runtime --prefix ../.. && tsc --build tsconfig.json",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@a5c-ai/agent-core": "5.0.0",
    "@a5c-ai/agent-runtime": "5.0.0",
    "@a5c-ai/agent-platform": "5.0.0",
    "@a5c-ai/agent-mux": "^5.0.0",
    "@a5c-ai/babysitter-sdk": "5.0.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@sinclair/typebox": "^0.34.48"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "rimraf": "^6.1.3",
    "typescript": "^5.4.2",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/babysitter.git",
    "directory": "packages/omni"
  },
  "homepage": "https://github.com/a5c-ai/babysitter/tree/main/packages/omni#readme",
  "bugs": {
    "url": "https://github.com/a5c-ai/babysitter/issues"
  },
  "keywords": [
    "babysitter",
    "omni",
    "agent",
    "orchestration",
    "unified"
  ],
  "atlas": {
    "layers": [
      "L4",
      "L5",
      "L6"
    ],
    "muxes": []
  }
}
