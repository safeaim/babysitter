{
  "name": "@a5c-ai/babysitter-sdk",
  "version": "0.0.187",
  "description": "Storage and run-registry primitives for event-sourced babysitter workflows.",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "babysitter-sdk": "dist/cli/main.js",
    "babysitter": "dist/cli/main.js",
    "babysitter-mcp-server": "dist/cli/mcpServeEntry.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-template-assets.cjs",
    "sync:command-templates": "node ../../scripts/sync-sdk-command-templates.cjs",
    "check:command-templates": "node ../../scripts/sync-sdk-command-templates.cjs --check",
    "clean": "rimraf dist",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:cli": "node scripts/smoke-cli.js --runs-dir packages/sdk/test-fixtures/cli/runs/smoke"
  },
  "dependencies": {
    "@agentsh/secure-sandbox": "^0.1.7",
    "@mariozechner/pi-coding-agent": "*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@sinclair/typebox": "^0.34.48",
    "fs-extra": "^11.2.0",
    "ink": "^4.4.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "ulid": "^2.3.0",
    "ws": "^8.20.0"
  },
  "optionalDependencies": {
    "@vscode/ripgrep": "^1.15.9",
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.28",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "ink-testing-library": "^3.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.2",
    "vitest": "^4.0.18"
  }
}
