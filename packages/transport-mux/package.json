{
  "name": "@a5c-ai/transport-mux",
  "version": "0.4.9",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Internal placeholder workspace for a future transport/provider mux seam",
  "author": "a5c-ai",
  "homepage": "https://github.com/a5c-ai/babysitter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/babysitter.git",
    "directory": "packages/transport-mux"
  },
  "bugs": {
    "url": "https://github.com/a5c-ai/babysitter/issues"
  },
  "keywords": [
    "agent-mux",
    "transport",
    "provider",
    "proxy",
    "llm"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc --build && tsc --emitDeclarationOnly --declarationMap false -p tsconfig.json",
    "scorecard:migration": "node ./scripts/migration-scorecard.mjs",
    "test:unit": "vitest run --root ../.. --config vitest.config.ts packages/transport-mux/tests",
    "test:e2e": "vitest run --root ../.. --config vitest.config.ts packages/transport-mux/tests/e2e",
    "test": "npm run test:unit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@a5c-ai/agent-mux-core": "0.4.9",
    "hono": "^4.12.14"
  }
}
