{
  "name": "sample-plugin",
  "version": "1.0.0",
  "description": "A sample plugin demonstrating the Unified Plugin Format",
  "author": "a5c.ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/a5c-ai/babysitter"
  },
  "keywords": ["sample", "demo"],
  "hooks": {
    "SessionStart": "hooks-proxy",
    "Stop": "hooks-proxy",
    "UserPromptSubmit": "hooks-proxy",
    "PreToolUse": "hooks-proxy"
  },
  "commands": "commands",
  "skills": [
    { "name": "greet", "file": "skills/greet/SKILL.md" }
  ],
  "include": [
    "versions.json",
    "assets/*"
  ],
  "targets": {
    "gemini": {
      "contextFileName": "GEMINI.md",
      "extraFiles": {
        "GEMINI.md": "This plugin provides greeting functionality for Gemini CLI."
      }
    }
  }
}
