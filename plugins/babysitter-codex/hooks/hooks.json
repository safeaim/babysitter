{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_TYPE=session-start ADAPTER_NAME=codex PLUGIN_ROOT=. bash ./hooks/babysitter-proxied-session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_TYPE=stop ADAPTER_NAME=codex PLUGIN_ROOT=. bash ./hooks/babysitter-proxied-stop.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_TYPE=user-prompt-submit ADAPTER_NAME=codex PLUGIN_ROOT=. bash ./hooks/babysitter-proxied-user-prompt-submit.sh"
          }
        ]
      }
    ]
  }
}