{
  "description": "babysitter plugin hooks for Gemini CLI",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "name": "babysitter-session-start",
            "type": "command",
            "command": "HOOK_TYPE=session-start ADAPTER_NAME=gemini PLUGIN_ROOT=${GEMINI_EXTENSION_PATH} bash ${GEMINI_EXTENSION_PATH}/hooks/babysitter-proxied-session-start.sh",
            "timeout": 30000,
            "description": "babysitter SessionStart hook"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "name": "babysitter-after-agent",
            "type": "command",
            "command": "HOOK_TYPE=after-agent ADAPTER_NAME=gemini PLUGIN_ROOT=${GEMINI_EXTENSION_PATH} bash ${GEMINI_EXTENSION_PATH}/hooks/babysitter-proxied-after-agent.sh",
            "timeout": 30000,
            "description": "babysitter AfterAgent hook"
          }
        ]
      }
    ]
  }
}