{
  "name": "babysitter",
  "version": "5.0.0",
  "description": "Orchestrate complex, multi-step workflows with event-sourced state management, hook-based extensibility, and human-in-the-loop approval",
  "author": "a5c.ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/a5c-ai/babysitter"
  },
  "keywords": [
    "orchestration", "workflow", "automation", "event-sourced",
    "hooks", "TDD", "quality-convergence", "agent", "LLM"
  ],
  "hooks": {
    "SessionStart": "hooks/session-start.sh",
    "Stop": "hooks/stop.sh",
    "UserPromptSubmit": "hooks/user-prompt-submit.sh",
    "PreToolUse": "hooks/pre-tool-use.sh",
    "PostToolUse": "hooks/post-tool-use.sh",
    "SubagentStop": "hooks/subagent-stop.sh",
    "Notification": "hooks/notification.sh",
    "PreCompact": "hooks/pre-compact.sh",
    "AfterAgent": "hooks/after-agent.sh",
    "SessionEnd": "hooks/session-end.sh",
    "SessionIdle": "hooks/session-idle.sh",
    "ShellEnv": "hooks/shell-env.sh",
    "BeforePromptBuild": "hooks/before-prompt-build.sh",
    "BeforeProviderRequest": "hooks/before-provider-request.sh"
  },
  "commands": "commands",
  "skills": [
    { "name": "babysit", "file": "skills/babysit/SKILL.md" }
  ],
  "include": [
    "versions.json",
    "hooks/"
  ],
  "hookConfig": {
    "proxyAdapter": true
  },
  "targets": {
    "codex": {
      "npmPackageName": "@a5c-ai/babysitter-codex"
    },
    "gemini": {
      "extraFiles": {
        "GEMINI.md": "file:per-harness/gemini/GEMINI.md"
      }
    },
    "github-copilot": {
      "extraFiles": {
        "AGENTS.md": "file:per-harness/github/AGENTS.md"
      }
    },
    "pi": {
      "npmPackageName": "@a5c-ai/babysitter-pi",
      "extraFiles": {
        "AGENTS.md": "file:per-harness/pi/AGENTS.md"
      }
    },
    "oh-my-pi": {
      "npmPackageName": "@a5c-ai/babysitter-omp",
      "extraFiles": {
        "AGENTS.md": "file:per-harness/omp/AGENTS.md"
      }
    }
  }
}
