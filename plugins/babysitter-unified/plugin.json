{
  "name": "babysitter",
  "version": "5.0.0",
  "description": "Orchestrate complex, multi-step workflows with event-sourced state management, hook-based extensibility, and human-in-the-loop approval",
  "author": "a5c.ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/a5c-ai/babysitter"
  },
  "keywords": [
    "orchestration",
    "workflow",
    "automation",
    "event-sourced",
    "hooks",
    "TDD",
    "quality-convergence",
    "agent",
    "LLM"
  ],
  "hooks": {
    "SessionStart": "hooks-proxy",
    "Stop": "hooks-proxy",
    "UserPromptSubmit": "hooks-proxy",
    "PreToolUse": "hooks-proxy",
    "PostToolUse": "hooks-proxy",
    "SubagentStop": "hooks-proxy",
    "Notification": "hooks-proxy",
    "PreCompact": "hooks-proxy",
    "AfterAgent": "hooks-proxy",
    "SessionEnd": "hooks-proxy",
    "SessionIdle": "hooks-proxy",
    "ShellEnv": "hooks-proxy",
    "BeforePromptBuild": "hooks-proxy",
    "BeforeProviderRequest": "hooks-proxy"
  },
  "commands": "../babysitter/commands",
  "skills": [
    { "name": "babysit", "file": "../babysitter/skills/babysit/SKILL.md" }
  ],
  "include": [
    "versions.json"
  ],
  "targets": {
    "claude-code": {
      "hooks": {
        "AfterAgent": null,
        "SessionEnd": null,
        "SessionIdle": null,
        "ShellEnv": null,
        "BeforePromptBuild": null,
        "BeforeProviderRequest": null
      }
    },
    "codex": {
      "npmPackageName": "@a5c-ai/babysitter-codex",
      "hooks": {
        "PreToolUse": null,
        "PostToolUse": null,
        "SubagentStop": null,
        "Notification": null,
        "PreCompact": null,
        "AfterAgent": null,
        "SessionEnd": null,
        "SessionIdle": null,
        "ShellEnv": null,
        "BeforePromptBuild": null,
        "BeforeProviderRequest": null
      }
    },
    "cursor": {
      "hooks": {
        "UserPromptSubmit": null,
        "PreToolUse": null,
        "PostToolUse": null,
        "SubagentStop": null,
        "Notification": null,
        "PreCompact": null,
        "AfterAgent": null,
        "SessionEnd": null,
        "SessionIdle": null,
        "ShellEnv": null,
        "BeforePromptBuild": null,
        "BeforeProviderRequest": null
      }
    },
    "gemini": {
      "hooks": {
        "Stop": null,
        "UserPromptSubmit": null,
        "PreToolUse": null,
        "PostToolUse": null,
        "SubagentStop": null,
        "Notification": null,
        "PreCompact": null,
        "SessionEnd": null,
        "SessionIdle": null,
        "ShellEnv": null,
        "BeforeProviderRequest": null
      },
      "extraFiles": {
        "GEMINI.md": "file:per-harness/gemini/GEMINI.md"
      }
    },
    "github-copilot": {
      "hooks": {
        "Stop": null,
        "PreToolUse": null,
        "PostToolUse": null,
        "SubagentStop": null,
        "Notification": null,
        "PreCompact": null,
        "AfterAgent": null,
        "SessionIdle": null,
        "ShellEnv": null,
        "BeforePromptBuild": null,
        "BeforeProviderRequest": null
      },
      "extraFiles": {
        "AGENTS.md": "file:per-harness/github/AGENTS.md"
      }
    },
    "pi": {
