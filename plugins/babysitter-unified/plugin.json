  "sdk": {
    "package": "@a5c-ai/babysitter-sdk",
    "cli": "babysitter",
    "proxyPackage": "@a5c-ai/hooks-mux-cli",
    "scope": "@a5c-ai",
    "envPrefix": "BABYSITTER",
    "stateDir": ".a5c"
  }
}
