{
  "name": "babysitter",
  "version": "5.0.0",
  "description": "Orchestrate complex, multi-step workflows with event-sourced state management, hook-based extensibility, and human-in-the-loop approval",
  "author": "a5c.ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/a5c-ai/babysitter"
  },
  "keywords": [
    "orchestration",
    "workflow",
    "automation",
    "event-sourced",
    "hooks",
    "TDD",
    "quality-convergence",
    "agent",
    "LLM"
  ],
  "hooks": {
    "SessionStart": "hooks/session-start.sh",
    "Stop": "hooks/stop.sh",
    "UserPromptSubmit": "hooks/user-prompt-submit.sh",
    "PreToolUse": "hooks/pre-tool-use.sh",
    "PostToolUse": "hooks/post-tool-use.sh",
    "SubagentStop": "hooks/subagent-stop.sh",
    "Notification": "hooks/notification.sh",
    "PreCompact": "hooks/pre-compact.sh",
    "AfterAgent": "hooks/after-agent.sh",
    "SessionEnd": "hooks/session-end.sh",
    "SessionIdle": "hooks/session-idle.sh",
    "ShellEnv": "hooks/shell-env.sh",
    "BeforePromptBuild": "hooks/before-prompt-build.sh",
    "BeforeProviderRequest": "hooks/before-provider-request.sh"
  },
  "hookFilePattern": "{{name}}-proxied-{{native}}.sh",
  "commands": "commands",
  "skills": [
    {
      "name": "babysit",
      "file": "skills/babysit/SKILL.md"
    }
  ],
  "include": [
    "versions.json",
    "hooks/"
  ],
  "targets": {
    "claude-code": {
      "hookConfig": {
        "matchers": {
          "PreToolUse": "Bash"
        }
      },
      "extraFiles": {
        "README.md": "file:per-harness/claude-code/README.md"
      }
    },
    "codex": {
      "npmPackageName": "@a5c-ai/babysitter-codex",
      "harnessManifest": {
        "skills": "./skills/",
        "hooks": "./hooks/hooks.json",
        "apps": "./.app.json",
        "interface": {
          "displayName": "Babysitter",
          "shortDescription": "Run Babysitter orchestration flows from Codex",
          "longDescription": "Babysitter adds orchestration entrypoints such as $call, $plan, and $resume, plus Codex lifecycle hooks that keep runs and workspace state in sync.",
          "developerName": "a5c.ai",
          "category": "Coding",
          "capabilities": [
            "Interactive",
            "Read",
            "Write"
          ],
          "websiteURL": "https://github.com/a5c-ai/babysitter",
          "privacyPolicyURL": "https://github.com/a5c-ai/babysitter",
          "termsOfServiceURL": "https://github.com/a5c-ai/babysitter",
          "defaultPrompt": [
            "Use Babysitter to start a new orchestration run",
            "Plan a Babysitter workflow before executing it",
            "Resume the latest Babysitter run in this workspace"
          ],
          "brandColor": "#0F766E",
          "composerIcon": "./assets/icon.svg",
          "logo": "./assets/logo.png"
        },
        "author": {
          "name": "a5c.ai",
          "email": "support@a5c.ai"
        },
        "homepage": "https://github.com/a5c-ai/babysitter/tree/main/plugins/babysitter-codex#readme",
        "repository": "https://github.com/a5c-ai/babysitter"
      },
      "extraFiles": {
        "skills/babysit/SKILL.md": "file:per-harness/codex/babysit-SKILL.md",
        "assets/icon.svg": "file:per-harness/codex/assets/icon.svg",
        "assets/logo.png": "file:per-harness/codex/assets/logo.png",
        "assets/logo.svg": "file:per-harness/codex/assets/logo.svg",
        "bin/install-shared.js": "file:per-harness/codex/bin/install-shared.js",
        "README.md": "file:per-harness/codex/README.md"
      }
    },
    "cursor": {
      "harnessManifest": {
        "skills": "skills/",
        "commands": "commands/",
        "hooks": "hooks/hooks-cursor.json",
        "author": {
          "name": "a5c.ai",
          "email": "support@a5c.ai"
        },
        "homepage": "https://github.com/a5c-ai/babysitter/tree/main/plugins/babysitter-cursor#readme",
        "repository": "https://github.com/a5c-ai/babysitter"
      },
      "extraFiles": {
        "skills/babysit/SKILL.md": "file:per-harness/cursor/babysit-SKILL.md",
        "bin/install-shared.js": "file:per-harness/cursor/bin/install-shared.js",
        "README.md": "file:per-harness/cursor/README.md"
      }
    },
    "gemini": {
      "extraFiles": {
        "GEMINI.md": "file:per-harness/gemini/GEMINI.md",
        "skills/babysit/SKILL.md": "file:per-harness/gemini/babysit-SKILL.md",
        "bin/cli.js": "file:per-harness/gemini/bin/cli.js",
        "bin/postinstall.js": "file:per-harness/gemini/bin/postinstall.js",
        "bin/preuninstall.js": "file:per-harness/gemini/bin/preuninstall.js",
        "README.md": "file:per-harness/gemini/README.md"
      }
    },
    "github-copilot": {
      "npmPackageName": "@a5c-ai/babysitter-github",
      "extraFiles": {
        "AGENTS.md": "file:per-harness/github/AGENTS.md",
        "skills/babysit/SKILL.md": "file:per-harness/github/babysit-SKILL.md",
        "bin/install-shared.js": "file:per-harness/github/bin/install-shared.js",
        "README.md": "file:per-harness/github/README.md"
      }
    },
    "pi": {
      "npmPackageName": "@a5c-ai/babysitter-pi",
      "extraFiles": {
        "AGENTS.md": "file:per-harness/pi/AGENTS.md",
        "skills/babysit/SKILL.md": "file:per-harness/pi/babysit-SKILL.md",
        "extensions/index.ts": "file:per-harness/pi/extensions-index.ts",
        "README.md": "file:per-harness/pi/README.md"
      }
    },
    "oh-my-pi": {
      "npmPackageName": "@a5c-ai/babysitter-omp",
      "extraFiles": {
        "AGENTS.md": "file:per-harness/omp/AGENTS.md",
        "skills/babysit/SKILL.md": "file:per-harness/omp/babysit-SKILL.md",
        "extensions/index.ts": "file:per-harness/omp/extensions-index.ts",
        "README.md": "file:per-harness/omp/README.md"
      }
    },
    "opencode": {
      "extraFiles": {
        "skills/babysit/SKILL.md": "file:per-harness/opencode/babysit-SKILL.md",
        "commands/status.md": "file:per-harness/opencode/status-command.md",
        "skills/accomplish-status/SKILL.md": "file:per-harness/opencode/accomplish-status-skill/SKILL.md",
        "bin/install-shared.js": "file:per-harness/opencode/bin/install-shared.js",
        "README.md": "file:per-harness/opencode/README.md"
      }
    },
    "openclaw": {
      "extraFiles": {
        "skills/babysit/SKILL.md": "file:per-harness/openclaw/babysit-SKILL.md",
        "commands/babysit.md": "file:per-harness/openclaw/babysit-command.md",
        "extensions/index.ts": "file:per-harness/openclaw/extensions-index.ts",
        "README.md": "file:per-harness/openclaw/README.md"
      }
    }
  }
}
