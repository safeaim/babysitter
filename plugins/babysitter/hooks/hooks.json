{
  "description": "babysitter plugin hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @a5c-ai/hooks-mux-cli invoke --adapter claude --handler \"bash ${CLAUDE_PLUGIN_ROOT}/hooks/babysitter-proxied-session-start.sh\" --json"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @a5c-ai/hooks-mux-cli invoke --adapter claude --handler \"bash ${CLAUDE_PLUGIN_ROOT}/hooks/babysitter-proxied-stop.sh\" --json"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @a5c-ai/hooks-mux-cli invoke --adapter claude --handler \"bash ${CLAUDE_PLUGIN_ROOT}/hooks/babysitter-proxied-user-prompt-submit.sh\" --json"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @a5c-ai/hooks-mux-cli invoke --adapter claude --handler \"bash ${CLAUDE_PLUGIN_ROOT}/hooks/babysitter-proxied-pre-tool-use.sh\" --json"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @a5c-ai/hooks-mux-cli invoke --adapter claude --handler \"bash ${CLAUDE_PLUGIN_ROOT}/hooks/babysitter-proxied-post-tool-use.sh\" --json"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @a5c-ai/hooks-mux-cli invoke --adapter claude --handler \"bash ${CLAUDE_PLUGIN_ROOT}/hooks/babysitter-proxied-subagent-stop.sh\" --json"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @a5c-ai/hooks-mux-cli invoke --adapter claude --handler \"bash ${CLAUDE_PLUGIN_ROOT}/hooks/babysitter-proxied-notification.sh\" --json"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @a5c-ai/hooks-mux-cli invoke --adapter claude --handler \"bash ${CLAUDE_PLUGIN_ROOT}/hooks/babysitter-proxied-pre-compact.sh\" --json"
          }
        ]
      }
    ]
  }
}
